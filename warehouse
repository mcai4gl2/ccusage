#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG="$DIR/apps/warehouse"

if [[ ! -d "$PKG/node_modules/duckdb-async" ]]; then
  echo "Installing warehouse dependencies..." >&2
  (cd "$PKG" && npm install --no-save 2>/dev/null || npm install)
fi

exec node --experimental-strip-types "$PKG/src/cli.ts" "$@"
