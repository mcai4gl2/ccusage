#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG="$DIR/apps/warehouse"

if [[ ! -d "$PKG/node_modules/duckdb-async" ]]; then
  echo "Installing warehouse dependencies..." >&2
  (cd "$PKG" && npm install --no-workspaces)
fi

exec "$PKG/node_modules/.bin/tsx" "$PKG/src/cli.ts" "$@"
